@startuml architecture-technical-v2
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam ArrowColor #555555
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825

skinparam component {
  BackgroundColor #EEF2FF
  BorderColor #6366F1
  FontColor #1E1B4B
}
skinparam database {
  BackgroundColor #F0FDF4
  BorderColor #22C55E
}
skinparam actor {
  BackgroundColor #F5F3FF
  BorderColor #8B5CF6
}
skinparam queue {
  BackgroundColor #FFF7ED
  BorderColor #F97316
}
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #94A3B8
}

title LaunchLens v2 — Technical Architecture (Parallel Execution)

actor "User\n(Browser)" as USER

rectangle "Frontend\nNext.js 14 · Vercel" as FE_BOX {
  component "page.tsx\n(React client)" as PAGE
  component "api.ts\n(fetch wrapper\nstage timer)" as APITS
  component "PipelineProgress.tsx\n(step counter · elapsed · retrying banner)" as PROG
  component "ReportView.tsx\n(tabs: Overview / Audience / Launch Copy)" as REPORT
}

rectangle "Backend\nFastAPI · Railway" as BE_BOX {
  component "POST /launch\nmain.py" as ROUTE

  rectangle "LangGraph State Machine\ngraph.py · PipelineState TypedDict" as GRAPH {
    component "Node 1\nproduct_analyst_node" as N1
    component "Node 2\ncommunity_researcher_node" as N2
    component "Node 3\nrag_synthesizer_node" as N3
    component "Node 4\npmf_scorer_node" as N4
    component "Node 5\ngtm_copywriter_node" as N5
    component "Node 6\nassemble_report_node" as N6
    component "_retry_on_rate_limit()\n429 · 503 · backoff" as RETRY
  }

  rectangle "Agent Layer — agents/" as AGENTS {
    component "product_analyst.py\nLangChain · with_structured_output" as A1

    rectangle "⚡ asyncio.gather — 3 hypotheses in parallel\nSemaphore(3) caps concurrency" as PAR_RESEARCH {
      component "community_researcher.py\nLangGraph prebuilt ReAct\n[hypothesis 1]" as A2a
      component "community_researcher.py\nLangGraph prebuilt ReAct\n[hypothesis 2]" as A2b
      component "community_researcher.py\nLangGraph prebuilt ReAct\n[hypothesis 3]" as A2c
    }

    component "rag_pipeline.py\nembed_and_store()\nshared Chroma instance" as RAG

    rectangle "⚡ asyncio.gather — 3 syntheses in parallel\nshared read-only vector store" as PAR_SYNTH {
      component "rag_synthesizer.py\nChroma retrieval + LLM\n[hypothesis 1]" as A3a
      component "rag_synthesizer.py\nChroma retrieval + LLM\n[hypothesis 2]" as A3b
      component "rag_synthesizer.py\nChroma retrieval + LLM\n[hypothesis 3]" as A3c
    }

    component "pmf_scorer.py\nChain-of-thought + parse_scoring_response()\nstate-machine parser for multi-line output" as A4

    rectangle "⚡ asyncio.gather — 3 copy pieces in parallel" as PAR_COPY {
      component "gtm_copywriter.py\ncold_dm_chain" as A5a
      component "gtm_copywriter.py\nreddit_angle_chain" as A5b
      component "gtm_copywriter.py\nlanding_page_chain" as A5c
    }
  }

  component "MCP Server\nmcp_server.py" as MCP
  database "Chroma\n(in-memory · one per session_id)" as CHROMA
}

rectangle "External APIs" as EXT {
  component "Gemini 2.5 Flash\nLLM calls" as GEMINI
  component "gemini-embedding-001\nEmbeddings" as EMBED
  component "Reddit JSON API\npublic · no auth" as REDDIT
  component "HN Algolia API\nfree · no auth" as HN
}

rectangle "Pydantic Schemas\nschemas.py — single source of truth" as SCHEMAS {
  component "ProductAnalysis\n(3 ICP hypotheses)" as S1
  component "CommunityEvidence\n(posts per hypothesis)" as S2
  component "SynthesisResult\n(pain_confirmed · confidence)" as S3
  component "PMFScore\n(score · verdict · strongest_signal · biggest_gap)" as S4
  component "GTMPack\n(DM · Reddit · headline · subheadline)" as S5
  component "LaunchLensReport\n(final assembled output)" as S6
}

' ── User flow ──────────────────────────────────────────────
USER --> PAGE : paste product description\nclick Validate my idea
PAGE --> APITS : runPipeline(description)
APITS --> ROUTE : POST /launch\n{ product_description }

' ── Node 1 ─────────────────────────────────────────────────
ROUTE --> N1
N1 --> A1 : invoke
A1 --> GEMINI : with_structured_output → ProductAnalysis
A1 --> S1
N1 --> N2

' ── Node 2 — parallel research ─────────────────────────────
N2 --> PAR_RESEARCH : asyncio.gather(*[research_with_sem(h) for h in hypotheses])
PAR_RESEARCH --> A2a
PAR_RESEARCH --> A2b
PAR_RESEARCH --> A2c
A2a --> MCP
A2b --> MCP
A2c --> MCP
MCP --> REDDIT
MCP --> HN
A2a --> S2
A2b --> S2
A2c --> S2
N2 --> N3

' ── Node 3 — embed once, synthesize in parallel ────────────
N3 --> RAG : embed_and_store(all evidence, session_id) — ONE PASS
RAG --> EMBED : batch embed
RAG --> CHROMA : store vectors
N3 --> PAR_SYNTH : asyncio.gather(*[synthesize_hypothesis(h, store) for h in hypotheses])
PAR_SYNTH --> A3a
PAR_SYNTH --> A3b
PAR_SYNTH --> A3c
A3a --> CHROMA : semantic search (read-only)
A3b --> CHROMA : semantic search (read-only)
A3c --> CHROMA : semantic search (read-only)
A3a --> GEMINI
A3b --> GEMINI
A3c --> GEMINI
A3a --> S3
A3b --> S3
A3c --> S3
N3 --> N4

' ── Node 4 ─────────────────────────────────────────────────
N4 --> A4
A4 --> GEMINI : chain-of-thought scoring
A4 --> S4
N4 -right-> N5 : [verdict: moderate | strong]
N4 -down-> N6 : [verdict: weak | insufficient]

' ── Node 5 — parallel copy generation ─────────────────────
N5 --> PAR_COPY : asyncio.gather(dm, reddit, landing)
PAR_COPY --> A5a
PAR_COPY --> A5b
PAR_COPY --> A5c
A5a --> GEMINI
A5b --> GEMINI
A5c --> GEMINI
A5a --> S5
A5b --> S5
A5c --> S5
N5 --> N6

' ── Node 6 + response ──────────────────────────────────────
N6 --> S6 : assemble LaunchLensReport
S6 --> ROUTE : JSON response
ROUTE --> APITS : LaunchLensReport
APITS --> PROG : stage + elapsed updates
APITS --> REPORT : render full report (tabbed UI)
REPORT --> USER : Overview · Audience · Launch Copy tabs

' ── Retry wrapper ───────────────────────────────────────────
RETRY .. N1
RETRY .. N2
RETRY .. N3
RETRY .. N4
RETRY .. N5

note right of RETRY
  All 5 LLM nodes wrapped.
  Retries up to 4× on:
  • 429 RESOURCE_EXHAUSTED
  • 503 UNAVAILABLE
  Parses retryDelay from error,
  falls back to 60s wait.
end note

note bottom of CHROMA
  One Chroma instance
  per session_id.
  Embedded ONCE, then
  read concurrently by
  all 3 synthesis workers.
  Destroyed after response.
end note

note right of N4
  Conditional routing:
  should_write_copy()
  moderate/strong → Node 5
  weak/insufficient → Node 6
  
  parse_scoring_response():
  state-machine parser captures
  multi-line strongest_signal
  and biggest_gap sections.
end note

note right of PAR_RESEARCH
  Semaphore(3) caps
  concurrent API calls.
  Was: ~75s sequential.
  Now: ~25s parallel.
end note

note right of PAR_COPY
  All 3 LLM calls are
  fully independent.
  Was: ~22s sequential.
  Now: ~7s parallel.
end note

@enduml
